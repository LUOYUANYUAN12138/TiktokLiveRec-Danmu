<ui:FluentWindow x:Class="TiktokLiveRec.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:b="http://schemas.github.com/computedbehaviors/2024/xaml"
                 xmlns:c="http://schemas.github.com/computedconverters/2024/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
                 xmlns:local="clr-namespace:TiktokLiveRec"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta"
                 Title="TiktokLiveRec"
                 Width="1120"
                 Height="720"
                 MinWidth="980"
                 MinHeight="680"
                 d:Background="#FF101010"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">
    <Grid>
        <ui:Grid Margin="8,42,8,8" RowDefinitions="Auto,*,Auto">
            <ui:Grid.Resources>
                <c:ValueConverterGroup x:Key="NotZeroIntToToVisibilityConverter">
                    <c:IntToBoolConverter TrueValue="0" />
                    <c:BoolToVisibilityConverter />
                </c:ValueConverterGroup>
                <Style x:Key="ToolbarButtonTextStyle" TargetType="TextBlock">
                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                </Style>
                <Style x:Key="TrimmedCenteredTextStyle"
                       BasedOn="{StaticResource CenteredDataGridTextColumnElementStyle}"
                       TargetType="TextBlock">
                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                    <Setter Property="ToolTip" Value="{Binding}" />
                </Style>
                <Style x:Key="DanmuListBoxItemStyle" TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                </Style>
                <DataTemplate x:Key="DanmuRoomTemplate">
                    <Grid Margin="0,1" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="{Binding NickName}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding StreamStatusText}"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </ui:Grid.Resources>
            <ui:Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <ui:StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <Button MinWidth="80" Command="{Binding AddRoomCommand}">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Add}" />
                                <TextBlock Style="{StaticResource ToolbarButtonTextStyle}" Text="{I18N ButtonOfAdd}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                    <Button MinWidth="80" Command="{Binding OpenSettingsDialogCommand}">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Settings}" />
                                <TextBlock Style="{StaticResource ToolbarButtonTextStyle}" Text="{I18N ButtonOfSettings}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                </ui:StackPanel>
                <ui:StackPanel Grid.Column="1"
                               Margin="8,0,0,0"
                               Orientation="Horizontal"
                               Spacing="8">
                    <Button MinWidth="80" Command="{Binding OpenSaveFolderCommand}">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.FolderOpen}" />
                                <TextBlock Style="{StaticResource ToolbarButtonTextStyle}" Text="{I18N SaveFolder}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                </ui:StackPanel>
            </ui:Grid>
            <ui:Grid Grid.Row="1" Margin="0,8,0,0" ColumnDefinitions="2.1*,6,1.3*">
                <Grid Grid.Column="0" MinWidth="560">
                    <ui:StackPanel HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Opacity="0.8"
                                   Spacing="8"
                                   Visibility="{Binding RoomStatuses.Count, Converter={StaticResource NotZeroIntToToVisibilityConverter}}">
                        <ui:FontIcon FontFamily="{DynamicResource CustomSymbolThemeFontFamily}"
                                     FontSize="40"
                                     Glyph="{x:Static ui:CustomFontSymbols.Empty}" />
                        <TextBlock Text="{I18N EmptyRoomHint}" />
                    </ui:StackPanel>
                    <ui:BitmapIcon Width="100"
                                   Height="100"
                                   Margin="8"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   Opacity="0.5"
                                   ShowAsMonochrome="True"
                                   UriSource="pack://application:,,,/Assets/Background.png" />
                    <DataGrid Margin="0,0,0,0"
                              AutoGenerateColumns="False"
                              Background="Transparent"
                              CanUserAddRows="False"
                              CanUserSortColumns="True"
                              ColumnHeaderHeight="50"
                              DataGrid.CellStyle="{StaticResource CenteredDataGridCellStyle}"
                              DataGrid.ColumnHeaderStyle="{StaticResource CenteredDataGridColumnHeaderStyle}"
                              EnableColumnVirtualization="False"
                              EnableRowVirtualization="False"
                              IsReadOnly="True"
                              ItemsSource="{Binding RoomStatuses}"
                              RowHeight="40"
                              SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.ContextMenu>
                    <ContextMenu Loaded="{c:EventBinding ContextMenuLoadedCommand}">
                        <MenuItem Header="{Binding SelectedItem.NickName}" IsEnabled="False" />
                        <MenuItem Command="{Binding GotoRoomUrlCommand}" Header="{I18N GotoLiveRoom}">
                            <MenuItem.Icon>
                                <ui:FontIcon Margin="2,0,2,0"
                                             FontFamily="{StaticResource SymbolThemeFontFamily}"
                                             FontSize="16"
                                             Glyph="{x:Static ui:FontSymbols.OpenInNewWindow}" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Command="{Binding RowUpRoomUrlCommand}" Header="{I18N RowUpRoom}">
                            <MenuItem.Icon>
                                <ui:FontIcon Margin="2,0,2,0"
                                             FontFamily="{StaticResource SymbolThemeFontFamily}"
                                             FontSize="16"
                                             Glyph="{x:Static ui:FontSymbols.ChevronUp}" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Command="{Binding RowDownRoomUrlCommand}" Header="{I18N RowDownRoom}">
                            <MenuItem.Icon>
                                <ui:FontIcon Margin="2,0,2,0"
                                             FontFamily="{StaticResource SymbolThemeFontFamily}"
                                             FontSize="16"
                                             Glyph="{x:Static ui:FontSymbols.ChevronDown}" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Command="{Binding RemoveRoomUrlCommand}" Header="{I18N RemoveRoom}">
                            <MenuItem.Icon>
                                <ui:FontIcon Margin="2,0,2,0"
                                             FontFamily="{StaticResource SymbolThemeFontFamily}"
                                             FontSize="16"
                                             Glyph="{x:Static ui:FontSymbols.CalculatorMultiply}" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Command="{Binding OpenSaveFolderCommand}" Header="{I18N SaveFolder}">
                            <MenuItem.Icon>
                                <ui:FontIcon Margin="2,0,2,0"
                                             FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             FontSize="16"
                                             Glyph="{x:Static ui:FontSymbols.FolderOpen}" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Command="{Binding PlayRecordCommand}" Header="{I18N PlayRecord}">
                            <MenuItem.Icon>
                                <ui:FontIcon Margin="2,0,2,0"
                                             FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             FontSize="16"
                                             Glyph="{x:Static ui:FontSymbols.Play}" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Command="{Binding StopRecordCommand}" Header="{I18N StopRecord}">
                            <MenuItem.Icon>
                                <ui:FontIcon Margin="2,0,2,0"
                                             FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             FontSize="16"
                                             Glyph="{x:Static ui:FontSymbols.Stop}" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <!--<MenuItem Command="{Binding ShowRecordLogCommand}" Header="{I18N RecordLog}">
                            <MenuItem.Icon>
                                <ui:FontIcon Margin="2,0,2,0"
                                             FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             FontSize="16"
                                             Glyph="{x:Static ui:FontSymbols.List}" />
                            </MenuItem.Icon>
                        </MenuItem>-->
                        <Separator />
                        <MenuItem Header="{I18N SingleSettings}" IsEnabled="False" />
                        <MenuItem Command="{Binding IsToNotifyCommand}"
                                  Header="{I18N LiveNotification}"
                                  IsCheckable="True"
                                  IsChecked="{Binding SelectedItem.IsToNotify, Mode=TwoWay}"
                                  ToolTip="{I18N LiveNotificationHint}" />
                        <MenuItem Command="{Binding IsToRecordCommand}"
                                  Header="{I18N EnableRecord}"
                                  IsCheckable="True"
                                  IsChecked="{Binding SelectedItem.IsToRecord, Mode=TwoWay}"
                                  ToolTip="{I18N EnableRecordHint}" />
                    </ContextMenu>
                        </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                    <DataGridTemplateColumn Width="56">
                        <DataGridTemplateColumn.CellStyle>
                            <Style BasedOn="{StaticResource DefaultDataGridCellStyle}" TargetType="{x:Type DataGridCell}">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type DataGridCell}">
                                            <vio:PersonPicture Width="28"
                                                               Height="28"
                                                               ProfilePicture="{Binding AvatarThumbUrl}"
                                                               RenderOptions.BitmapScalingMode="HighQuality"
                                                               SnapsToDevicePixels="True" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Width="1.15*"
                                        Binding="{Binding NickName}"
                                        CellStyle="{StaticResource CenteredDataGridTextColumnCellStyle}"
                                        EditingElementStyle="{StaticResource CenteredDataGridTextColumnEditingElementStyle}"
                                        ElementStyle="{StaticResource TrimmedCenteredTextStyle}"
                                        Header="{I18N LiveRoom}"
                                        IsReadOnly="True"
                                        SortMemberPath="LiveRoom" />
                    <DataGridTextColumn Width="0.9*"
                                        Binding="{Binding StreamStatusText}"
                                        CellStyle="{StaticResource CenteredDataGridTextColumnCellStyle}"
                                        EditingElementStyle="{StaticResource CenteredDataGridTextColumnEditingElementStyle}"
                                        ElementStyle="{StaticResource TrimmedCenteredTextStyle}"
                                        Header="{I18N StreamStatus}"
                                        IsReadOnly="True"
                                        SortMemberPath="StreamStatusText" />
                    <DataGridTextColumn Width="0.9*"
                                        Binding="{Binding RecordStatusText}"
                                        CellStyle="{StaticResource CenteredDataGridTextColumnCellStyle}"
                                        EditingElementStyle="{StaticResource CenteredDataGridTextColumnEditingElementStyle}"
                                        ElementStyle="{StaticResource TrimmedCenteredTextStyle}"
                                        Header="{I18N RecordStatus}"
                                        IsReadOnly="True"
                                        SortMemberPath="RecordStatusText" />
                    <DataGridTextColumn Width="1.35*"
                                        Binding="{Binding RecordStatusHintText}"
                                        CellStyle="{StaticResource CenteredDataGridTextColumnCellStyle}"
                                        EditingElementStyle="{StaticResource CenteredDataGridTextColumnEditingElementStyle}"
                                        ElementStyle="{StaticResource TrimmedCenteredTextStyle}"
                                        Header="录制反馈"
                                        IsReadOnly="True"
                                        SortMemberPath="RecordStatusHintText" />
                    <DataGridTemplateColumn Width="180" Header="{I18N Operation}">
                        <DataGridTemplateColumn.CellStyle>
                            <Style BasedOn="{StaticResource DefaultDataGridCellStyle}" TargetType="{x:Type DataGridCell}">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type DataGridCell}">
                                            <ui:StackPanel HorizontalAlignment="Center"
                                                           Orientation="Horizontal"
                                                           Spacing="6">
                                                <Button Command="{Binding PlayRecordCommand}"
                                                        Padding="8,4"
                                                        Tag="{Binding}"
                                                        ToolTip="{I18N PlayRecord}">
                                                    <Button.Content>
                                                        <ui:StackPanel Orientation="Horizontal" Spacing="4">
                                                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Play}" />
                                                            <TextBlock Text="{I18N ButtonOfPlay}" TextTrimming="CharacterEllipsis" />
                                                        </ui:StackPanel>
                                                    </Button.Content>
                                                </Button>
                                                <Button Command="{Binding GotoRoomUrlCommand}"
                                                        Padding="8,4"
                                                        Tag="{Binding}"
                                                        ToolTip="{I18N GotoLiveRoom}">
                                                    <Button.Content>
                                                        <ui:StackPanel Orientation="Horizontal" Spacing="4">
                                                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.OpenInNewWindow}" />
                                                            <TextBlock Text="进入" TextTrimming="CharacterEllipsis" />
                                                        </ui:StackPanel>
                                                    </Button.Content>
                                                </Button>
                                            </ui:StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                    </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
                <Grid Grid.Column="1" Margin="8,0" Background="{DynamicResource ControlStrongStrokeColorDefaultBrush}">
                    <GridSplitter Width="6"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="Transparent"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext" />
                </Grid>
                <Border Grid.Column="2"
                        MinWidth="340"
                        Padding="10"
                        Background="{DynamicResource LayerFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <ui:Grid RowDefinitions="Auto,*">
                        <ui:Grid Margin="0,0,0,12" RowDefinitions="Auto,Auto">
                            <ui:Grid ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:ToggleSwitch IsChecked="{Binding IsEnableDanmu, Mode=TwoWay}" />
                                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="启用弹幕" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <ComboBox HorizontalContentAlignment="Stretch"
                                              ItemTemplate="{StaticResource DanmuRoomTemplate}"
                                              ItemsSource="{Binding DanmuRoomOptions}"
                                              SelectedItem="{Binding SelectedDanmuRoom, Mode=TwoWay}" />
                                </StackPanel>
                            </ui:Grid>
                            <ui:Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto">
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Text="{Binding DanmuStatusText}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding DanmuStatusText}" />
                                <Button Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Content="过滤">
                                    <Button.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="聊天" IsCheckable="True" IsChecked="{Binding ShowDanmuChat, Mode=TwoWay}" />
                                            <MenuItem Header="礼物" IsCheckable="True" IsChecked="{Binding ShowDanmuGift, Mode=TwoWay}" />
                                            <MenuItem Header="点赞" IsCheckable="True" IsChecked="{Binding ShowDanmuLike, Mode=TwoWay}" />
                                            <MenuItem Header="关注" IsCheckable="True" IsChecked="{Binding ShowDanmuFollow, Mode=TwoWay}" />
                                            <MenuItem Header="表情" IsCheckable="True" IsChecked="{Binding ShowDanmuEmoji, Mode=TwoWay}" />
                                            <Separator />
                                            <MenuItem Header="进入直播间" IsCheckable="True" IsChecked="{Binding ShowDanmuMember, Mode=TwoWay}" />
                                            <MenuItem Header="房间统计" IsCheckable="True" IsChecked="{Binding ShowDanmuRoomStats, Mode=TwoWay}" />
                                            <MenuItem Header="房间榜单" IsCheckable="True" IsChecked="{Binding ShowDanmuRoomRank, Mode=TwoWay}" />
                                            <MenuItem Header="粉丝团" IsCheckable="True" IsChecked="{Binding ShowDanmuFansClub, Mode=TwoWay}" />
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <i:Interaction.Behaviors>
                                        <b:LeftContextMenuBehavior />
                                    </i:Interaction.Behaviors>
                                </Button>
                                <Button Grid.Column="2"
                                        Margin="8,0,0,0"
                                        Command="{Binding ClearDanmuMessagesCommand}"
                                        Content="清空显示" />
                                <Button Grid.Column="3"
                                        Margin="8,0,0,0"
                                        Command="{Binding OpenDanmuLogFolderCommand}"
                                        Content="日志目录" />
                            </ui:Grid>
                        </ui:Grid>
                        <Grid Grid.Row="1">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Opacity="0.7"
                                        Visibility="{Binding DisplayedDanmuMessages.Count, Converter={StaticResource NotZeroIntToToVisibilityConverter}}">
                                <TextBlock FontSize="14"
                                           Text="开启弹幕并选择一个抖音房间后，这里会显示聊天和礼物消息。"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ListBox x:Name="DanmuListBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemsSource="{Binding DisplayedDanmuMessages}"
                                     ItemContainerStyle="{StaticResource DanmuListBoxItemStyle}"
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.CanContentScroll="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <ui:Grid Margin="0,0,0,6" ColumnDefinitions="Auto,*,Auto">
                                            <vio:PersonPicture Width="24"
                                                               Height="24"
                                                               Margin="0,0,8,0"
                                                               VerticalAlignment="Top"
                                                               ProfilePicture="{Binding UserAvatarUrl}" />
                                            <StackPanel Grid.Column="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding UserName}" />
                                                    <TextBlock Margin="8,0,0,0" FontSize="11" Opacity="0.55" Text="{Binding TimestampText}" />
                                                    <TextBlock Margin="8,0,0,0" FontSize="11" Opacity="0.5" Text="{Binding Method}" />
                                                </StackPanel>
                                                <TextBlock Margin="0,2,0,0"
                                                           Opacity="0.92"
                                                           Text="{Binding DisplayText}"
                                                           TextWrapping="WrapWithOverflow">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsGift}" Value="True">
                                                                    <Setter Property="Foreground" Value="#C68A00" />
                                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsSecondary}" Value="True">
                                                                    <Setter Property="Opacity" Value="0.6" />
                                                                    <Setter Property="FontSize" Value="11" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsGift, Converter={x:Static c:BoolToVisibilityConverter.Instance}}">
                                                <Image Width="20"
                                                       Height="20"
                                                       Margin="0,0,6,0"
                                                       Source="{Binding GiftIconUrl}" />
                                                <TextBlock FontSize="11"
                                                           Foreground="#C68A00"
                                                           Text="{Binding GiftName}" />
                                                <TextBlock Margin="4,0,0,0"
                                                           FontSize="11"
                                                           Foreground="#C68A00"
                                                           Text="{Binding GiftCount, StringFormat=x{0}}" />
                                            </StackPanel>
                                        </ui:Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </ui:Grid>
                </Border>
            </ui:Grid>
            <ui:Grid Grid.Row="2">
                <ui:StackPanel Margin="0,5,0,0"
                               HorizontalAlignment="Right"
                               Opacity="0.9"
                               Orientation="Horizontal"
                               Spacing="8">
                    <ContentControl ToolTip="{I18N LiveNotification}">
                        <c:If Condition="{Binding StatusOfIsToNotify, Mode=OneWay}">
                            <c:If.TrueValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                             Glyph="{x:Static ui:FontSymbols.Ringer}" />
                            </c:If.TrueValue>
                            <c:If.FalseValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                             Glyph="{x:Static ui:FontSymbols.Ringer}" />
                            </c:If.FalseValue>
                        </c:If>
                    </ContentControl>
                    <ContentControl ToolTip="{I18N EnableRecord}">
                        <c:If Condition="{Binding StatusOfIsToRecord, Mode=OneWay}">
                            <c:If.TrueValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                             Glyph="{x:Static ui:FontSymbols.Video}" />
                            </c:If.TrueValue>
                            <c:If.FalseValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                             Glyph="{x:Static ui:FontSymbols.Video}" />
                            </c:If.FalseValue>
                        </c:If>
                    </ContentControl>
                    <ContentControl ToolTip="{I18N UseProxy}">
                        <c:If Condition="{Binding StatusOfIsUseProxy, Mode=OneWay}">
                            <c:If.TrueValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                             Glyph="{x:Static ui:FontSymbols.VPN}" />
                            </c:If.TrueValue>
                            <c:If.FalseValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                             Glyph="{x:Static ui:FontSymbols.VPN}" />
                            </c:If.FalseValue>
                        </c:If>
                    </ContentControl>
                    <ContentControl ToolTip="{I18N KeepAwake}">
                        <c:If Condition="{Binding StatusOfIsUseKeepAwake, Mode=OneWay}">
                            <c:If.TrueValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                             Glyph="{x:Static ui:FontSymbols.Recent}" />
                            </c:If.TrueValue>
                            <c:If.FalseValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                             Glyph="{x:Static ui:FontSymbols.Recent}" />
                            </c:If.FalseValue>
                        </c:If>
                    </ContentControl>
                    <ContentControl ToolTip="{I18N AutoShutdown}">
                        <c:If Condition="{Binding StatusOfIsUseAutoShutdown, Mode=OneWay}">
                            <c:If.TrueValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                             Glyph="{x:Static ui:FontSymbols.PowerButton}" />
                            </c:If.TrueValue>
                            <c:If.FalseValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                             Glyph="{x:Static ui:FontSymbols.PowerButton}" />
                            </c:If.FalseValue>
                        </c:If>
                    </ContentControl>
                    <TextBlock FontSize="12"
                               Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                               Text="{Binding StatusOfAutoShutdownTime}"
                               ToolTip="{I18N AutoShutdown}"
                               Visibility="{Binding StatusOfIsUseAutoShutdown, Converter={x:Static c:BoolToVisibilityConverter.Instance}}" />
                    <Separator />
                    <ui:StackPanel Orientation="Horizontal" ToolTip="{I18N RoutineInterval}">
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="12"
                                   Opacity="0.6"
                                   Text="{Binding StatusOfRoutineIntervalWithUnit}"
                                   ToolTip="{I18N RoutineInterval}" />
                    </ui:StackPanel>
                    <Separator />
                    <TextBlock VerticalAlignment="Center"
                               FontSize="12"
                               Opacity="0.6"
                               Text="{Binding StatusOfRecordFormat}"
                               ToolTip="{I18N RecordFormat}" />
                </ui:StackPanel>
            </ui:Grid>
        </ui:Grid>
        <Grid>
            <ui:TitleBar Title="{I18N Title}" ShowMaximize="False">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="pack://application:,,,/Assets/Favicon.png" />
                </ui:TitleBar.Icon>
                <ui:TitleBar.TrailingContent>
                    <ui:Button Width="44"
                               Height="30"
                               Margin="0,-16,0,0"
                               Background="Transparent"
                               BorderBrush="Transparent"
                               CornerRadius="0"
                               Icon="{ui:SymbolIcon CaretDown16}">
                        <ui:Button.ContextMenu>
                            <ContextMenu FontSize="12">
                                <MenuItem Command="{Binding OpenSaveFolderCommand}" Header="{I18N SaveFolder}">
                                    <MenuItem.Icon>
